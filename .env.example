# .env.example — local dev defaults for docker-compose.
# Copy to .env (gitignored) and adjust as needed.
# All values have sensible defaults in docker-compose.yml, so this file
# is OPTIONAL: the stack will run with `make up` even without a .env.

# Postgres
POSTGRES_USER=unifleet
POSTGRES_PASSWORD=unifleet_dev_pw
POSTGRES_DB=unifleet

# App
BASE_URL=http://localhost:5000
PORT=5000
PERSISTENCE_BACKEND=csv
DATABASE_URL=postgresql://unifleet:unifleet_dev_pw@db:5432/unifleet

# Auth (defaults match the app's hardcoded fallbacks; override for non-dev use)
SUPPLIER_API_TOKEN=unifleet2025mvp
ADMIN_KEY=unifleet-admin
